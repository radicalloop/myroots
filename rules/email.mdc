# Email Rules

## Stack

- Provider: Resend (or SendGrid — follow project config)
- Template engine: React Email or Handlebars
- Sending: always async via queue — never blocking HTTP requests

---

## Architecture

```
Service → Queue (BullMQ) → Processor → EmailService → Provider (Resend)
```

Never send emails synchronously in HTTP handlers.

---

## EmailService

```ts
// src/modules/email/email.service.ts
@Injectable()
export class EmailService {
  private readonly logger = new Logger(EmailService.name);

  constructor(private readonly configService: ConfigService) {}

  async sendWelcome(to: string, name: string): Promise<void> {
    await this.send({
      to,
      subject: 'Welcome to the platform',
      template: 'welcome',
      context: { name },
    });
  }

  async sendOrderConfirmation(to: string, order: OrderSummary): Promise<void> {
    await this.send({
      to,
      subject: `Order #${order.id} confirmed`,
      template: 'order-confirmation',
      context: { order },
    });
  }

  async sendPasswordReset(to: string, resetUrl: string): Promise<void> {
    await this.send({
      to,
      subject: 'Reset your password',
      template: 'password-reset',
      context: { resetUrl, expiresIn: '30 minutes' },
    });
  }

  private async send(params: SendEmailParams): Promise<void> {
    try {
      // call Resend / SendGrid SDK here
      this.logger.log(`Email sent: ${params.template} → ${params.to}`);
    } catch (error) {
      this.logger.error(`Email failed: ${params.template} → ${params.to}`, error.stack);
      throw error;
    }
  }
}
```

