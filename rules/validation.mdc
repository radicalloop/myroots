## Common Validators

```ts
import {
  IsEmail, IsString, IsEnum, IsUUID, IsOptional, IsInt,
  IsBoolean, IsUrl, IsPhoneNumber, IsDate, IsPositive,
  MinLength, MaxLength, Min, Max, Matches, IsArray,
  ArrayMinSize, ValidateNested, IsNotEmpty,
} from 'class-validator';
import { Type } from 'class-transformer';

export class CreateUserDto {
  @IsEmail({}, { message: 'Must be a valid email address' })
  email: string;

  @IsString()
  @MinLength(8, { message: 'Password must be at least 8 characters' })
  @MaxLength(72)
  @Matches(/^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)/, {
    message: 'Password must contain uppercase, lowercase, and number',
  })
  password: string;

  @IsString()
  @IsNotEmpty()
  @MinLength(2)
  @MaxLength(100)
  name: string;

  @IsEnum(UserRole)
  role: UserRole;

  @IsOptional()
  @IsPhoneNumber()
  phone?: string;
}
```

