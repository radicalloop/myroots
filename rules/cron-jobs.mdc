# Cron Jobs Rules

## Stack

- NestJS `@nestjs/schedule` with `@Cron` decorator
- Cron jobs live in dedicated scheduler services

---

## Setup

```ts
// app.module.ts
ScheduleModule.forRoot(),
```

---

## Structure

```
src/modules/scheduler/
├── tasks/
│   ├── cleanup.task.ts
│   ├── report.task.ts
│   └── sync.task.ts
└── scheduler.module.ts
```

---

## Task Service

```ts
// tasks/cleanup.task.ts
import { Injectable, Logger } from '@nestjs/common';
import { Cron, CronExpression } from '@nestjs/schedule';

@Injectable()
export class CleanupTask {
  private readonly logger = new Logger(CleanupTask.name);

  constructor(
    private readonly userDb: UserDbService,
    private readonly notificationDb: NotificationDbService,
  ) {}

  @Cron(CronExpression.EVERY_DAY_AT_MIDNIGHT)
  async deleteExpiredTokens(): Promise<void> {
    this.logger.log('Running: deleteExpiredTokens');
    try {
      const deleted = await this.userDb.deleteExpiredRefreshTokens();
      this.logger.log(`Deleted ${deleted} expired tokens`);
    } catch (error) {
      this.logger.error('Failed: deleteExpiredTokens', error.stack);
    }
  }

  @Cron(CronExpression.EVERY_WEEK)
  async deleteOldNotifications(): Promise<void> {
    this.logger.log('Running: deleteOldNotifications');
    try {
      const cutoff = new Date();
      cutoff.setDate(cutoff.getDate() - 90);
      const deleted = await this.notificationDb.deleteOlderThan(cutoff);
      this.logger.log(`Deleted ${deleted} old notifications`);
    } catch (error) {
      this.logger.error('Failed: deleteOldNotifications', error.stack);
    }
  }

  @Cron('0 8 * * 1') // Every Monday at 8am
  async sendWeeklyDigest(): Promise<void> {
    this.logger.log('Running: sendWeeklyDigest');
    // enqueue email jobs for all subscribed users
  }
}
```

