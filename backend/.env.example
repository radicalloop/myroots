APP_ENV=development
PORT=3001
API_BASE_URL=http://localhost:3001/api

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/family_tree?connection_limit=20&pool_timeout=10

JWT_SECRET=change-me-to-a-random-secret-at-least-64-chars
JWT_REFRESH_SECRET=change-me-to-another-random-secret-at-least-64-chars

CORS_ORIGINS=http://localhost:3000,http://localhost:5173
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=100
REQUEST_TIMEOUT_MS=30000
BCRYPT_SALT_ROUNDS=10

# AWS S3 (required for image uploads)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
AWS_BUCKET_NAME=your_bucket_name
AWS_SIGNED_URL_EXPIRES_IN_SECONDS=3600
# Optional public CDN/base URL for chat images (otherwise presigned GET URLs are used)
# AWS_S3_PUBLIC_BASE_URL=https://your-bucket.s3.amazonaws.com

# Chat images uploaded for AI are deleted after this many hours
CHAT_IMAGE_RETENTION_HOURS=10

PROFILE_IMAGE_MAX_SIZE_MB=5
FRONT_URL=http://localhost:3000

# AI Chat (optional — leave blank to disable)
AI_MODAL=
AI_API_KEY=
AI_BASE_URL=
# Set to OpenAI or DeepSeek model to enable chat, e.g.:
# AI_MODAL=deepseek:deepseek-v4-pro
# AI_API_KEY=your-deepseek-api-key
# AI_BASE_URL=https://api.deepseek.com

# Or use OpenAI:
# AI_MODAL=openai:gpt-4o-mini
# AI_API_KEY=your-openai-api-key

AI_MAX_OUTPUT_TOKENS=800
AI_REQUEST_TIMEOUT_MS=30000


RESEND_API_KEY=
RESEND_FROM_EMAIL=